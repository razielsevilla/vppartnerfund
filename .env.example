# Frontend
VITE_API_URL=http://localhost:4000/api

# Backend
NODE_ENV=development
BACKEND_PORT=4000
CLIENT_ORIGIN=http://localhost:5173
SESSION_SECRET=change-me-before-production
SESSION_COOKIE_NAME=vp_partner_fund_session
SESSION_TTL_MS=28800000
DATABASE_CLIENT=sqlite
SQLITE_DB_PATH=./backend/prod.db
# Only required if DATABASE_CLIENT=pg
DATABASE_URL=postgres://user:password@localhost:5432/vppartnerfund

AUTH_VP_EMAIL=admin@devconlaguna.internal
AUTH_VP_PASSWORD=changeme
AUTH_LIAISON_EMAIL=team@devconlaguna.internal
AUTH_LIAISON_PASSWORD=changeme
AUTH_COMPLIANCE_EMAIL=team@devconlaguna.internal
AUTH_COMPLIANCE_PASSWORD=changeme-compliance
AUTH_DEVCON_EMAIL=team@devconlaguna.internal
AUTH_DEVCON_PASSWORD=changeme-devcon

# Legacy compatibility aliases (optional)
AUTH_ADMIN_EMAIL=admin@devconlaguna.internal
AUTH_ADMIN_PASSWORD=changeme
AUTH_TEAM_EMAIL=team@devconlaguna.internal
AUTH_TEAM_PASSWORD=changeme

ARTIFACT_LOCAL_ROOT=./uploads/artifacts
# Optional: disable automatic seed account creation at startup
DISABLE_AUTO_USER_SEED=false
AUTH_BCRYPT_ROUNDS=10
LOGIN_RATE_LIMIT_WINDOW_MS=600000
LOGIN_RATE_LIMIT_MAX=5
